# The pipeline reads these from the environment (see the README for how to set
# them). Get a free Adzuna key at https://developer.adzuna.com/ .
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Required to build the national map (393 metros): a free BLS key lifts the
# labor-force fetch from 25 requests/day (keyless) to 500 — the keyless quota runs
# out long before 393 metros, so pipeline/build_all.py checks for this key.
# Register at https://data.bls.gov/registrationEngine/ . NIOCCS coding is keyless.
BLS_API_KEY=

# For LLM occupation classification (parked — see ROADMAP "Occupations & skills").
# Get one at https://aistudio.google.com/apikey . Not needed for the map/sectors.
GEMINI_API_KEY=

# Copy this file to .env and fill in values; pipeline/geo.py auto-loads .env,
# so builds then run without passing keys inline. .env is gitignored.
