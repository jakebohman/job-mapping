# The pipeline reads these from the environment (see the README for how to set
# them). Get a free Adzuna key at https://developer.adzuna.com/ .
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional but needed for the national map (393 metros): a free BLS key lifts
# the labor-force fetch from 25 requests/day (keyless) to 500. Register at
# https://data.bls.gov/registrationEngine/ . The NIOCCS occupation coder is keyless.
BLS_API_KEY=

# For LLM occupation classification (ROADMAP task 5). Get one at
# https://aistudio.google.com/apikey . Not needed until then.
GEMINI_API_KEY=

# Copy this file to .env and fill in values; pipeline/geo.py auto-loads .env,
# so builds then run without passing keys inline. .env is gitignored.
