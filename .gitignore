# Secrets — never commit real keys (the .env.example template is tracked)
.env
.env.local

# NOTE: site/data/_*_cache.json are deliberately TRACKED, not ignored. They are
# the pipeline's accumulated state, not derived output: build_national.py and
# panel.py rewrite national.json/outliers.json wholesale from them, so a run that
# starts with an empty cache REPLACES the published data instead of extending it
# (a cold CI run once cut sector coverage from 147 metros to 70). Git is the only
# store that survives a failed run; freshness comes from measured_at/fetched_at
# aging, not from discarding the cache.

# DuckDB store (deferred to national scale; rebuilt, never committed)
*.duckdb
*.duckdb.wal

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node / frontend
node_modules/
dist/
