# Secrets — never commit real keys (the .env.example template is tracked)
.env
.env.local

# Panel's resumable fetch cache (regenerated by pipeline/panel.py)
site/data/_mix_cache.json

# DuckDB store (deferred to national scale; rebuilt, never committed)
*.duckdb
*.duckdb.wal

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node / frontend
node_modules/
dist/

# National map resumable count cache (regenerated)
site/data/_national_cache.json

# Labor-force cache (accumulates across runs; regenerated)
site/data/_lf_cache.json
